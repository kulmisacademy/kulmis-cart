generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  logo         String
  logoUrl      String?
  phone        String
  whatsapp     String?
  region       String
  district     String
  description  String
  bannerImage  String?
  rating       Float
  totalReviews Int
  isVerified   Boolean   @default(false)
  badges       String[]  @default([])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  products     Product[]
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  oldPrice    Float?
  image       String
  images      String[] @default([])
  videoUrl    String?
  createdAt   DateTime @default(now())
  category    String
  region      String
  district    String
  stockStatus String?
  storeSlug   String
  storeName   String
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([district])
  @@index([region])
  @@index([storeSlug])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sc_ad_events {
  id          String   @id
  ad_id       String
  customer_id String
  event_type  String
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  sc_ads      sc_ads   @relation(fields: [ad_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([ad_id, customer_id], map: "sc_ad_events_ad_customer_idx")
  @@index([ad_id], map: "sc_ad_events_ad_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sc_ads {
  id                 String         @id
  title              String
  type               String
  image_url          String?
  description        String?
  link               String?
  region_target      String?
  page_target        String
  is_active          Boolean        @default(true)
  max_views_per_user Int?
  popup_delay_ms     Int            @default(0)
  created_at         DateTime       @default(now()) @db.Timestamptz(6)
  updated_at         DateTime       @default(now()) @db.Timestamptz(6)
  sc_ad_events       sc_ad_events[]

  @@index([is_active, page_target], map: "sc_ads_active_page_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sc_chat_messages {
  id               String           @id
  conversation_id  String
  sender_role      String
  body             String
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  thread_id        String?
  sender_type      String?
  sender_id        String?
  message_type     String?
  message_text     String?
  product_json     String?
  sc_conversations sc_conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([conversation_id], map: "sc_chat_messages_conv_idx")
  @@index([thread_id, created_at], map: "sc_chat_messages_thread_idx")
}

model sc_chat_threads {
  id           String       @id
  customer_id  String
  store_slug   String
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  updated_at   DateTime     @default(now()) @db.Timestamptz(6)
  last_message String?
  sc_customers sc_customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([customer_id, store_slug])
  @@index([store_slug])
}

model sc_checkouts {
  id           String       @id
  customer_id  String
  full_name    String
  phone        String
  region       String
  district     String
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  sc_customers sc_customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([customer_id], map: "sc_checkouts_customer_idx")
  @@index([phone])
}

model sc_conversations {
  id               String             @id
  store_slug       String
  customer_id      String
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  sc_chat_messages sc_chat_messages[]
  sc_customers     sc_customers       @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([store_slug, customer_id])
  @@index([store_slug], map: "sc_conversations_store_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sc_customer_orders {
  id                 String               @id
  customer_id        String
  product_id         String
  store_slug         String
  store_name         String
  product_title      String
  product_url        String
  customer_name      String
  customer_phone     String
  customer_region    String
  customer_district  String
  status             String               @default("pending")
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  checkout_id        String?
  quantity           Int                  @default(1)
  unit_price         Decimal?             @db.Decimal(12, 2)
  sc_customers       sc_customers         @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sc_store_feedback  sc_store_feedback?
  sc_vendor_invoices sc_vendor_invoices[]

  @@index([customer_id], map: "sc_customer_orders_customer_idx")
  @@index([store_slug])
}

model sc_customers {
  id                 String               @id
  full_name          String
  email              String               @unique
  phone              String
  password_hash      String
  region             String
  district           String
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  sc_chat_threads    sc_chat_threads[]
  sc_checkouts       sc_checkouts[]
  sc_conversations   sc_conversations[]
  sc_customer_orders sc_customer_orders[]
  sc_store_feedback  sc_store_feedback[]
  sc_store_followers sc_store_followers[]
}

model sc_invoices {
  id              String   @id
  invoice_number  String   @unique
  source_key      String   @unique
  store_slug      String
  checkout_id     String?
  order_line_ids  String   @default("[]")
  customer_name   String
  customer_phone  String
  line_items_json String
  total_amount    Decimal  @db.Decimal(12, 2)
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  @@index([store_slug], map: "sc_invoices_store_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sc_password_resets {
  id          String   @id
  email       String
  role        String
  customer_id String?
  vendor_id   String?
  otp_hash    String
  expires_at  DateTime @db.Timestamptz(6)
  verified    Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@index([email, role])
}

model sc_plan_definitions {
  id                     String                   @id
  slug                   String                   @unique
  name                   String
  price_monthly_cents    Int                      @default(0)
  product_limit          Int?
  video_limit            Int?
  ai_enabled             Boolean                  @default(false)
  featured_priority      Int                      @default(0)
  is_active              Boolean                  @default(true)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  sc_store_subscriptions sc_store_subscriptions[]
}

model sc_platform_settings {
  id                     String @id @default("default")
  verification_fee_cents Int    @default(1000)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sc_store_feedback {
  id                 String             @id
  customer_id        String
  store_slug         String
  order_id           String             @unique
  rating             Int
  comment            String             @default("")
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  preset_option      String?
  sc_customers       sc_customers       @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sc_customer_orders sc_customer_orders @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([store_slug])
}

model sc_store_flags {
  store_slug  String  @id
  is_verified Boolean @default(false)
}

model sc_store_followers {
  id           String       @id
  customer_id  String
  store_slug   String
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  sc_customers sc_customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([customer_id, store_slug])
  @@index([store_slug], map: "sc_store_followers_slug_idx")
}

model sc_store_subscriptions {
  store_slug          String              @id
  plan_id             String
  expires_at          DateTime?           @db.Timestamptz(6)
  sc_plan_definitions sc_plan_definitions @relation(fields: [plan_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model sc_store_view_counts {
  store_slug String   @id
  view_count BigInt   @default(0)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model sc_store_views {
  store_slug String   @id
  views      BigInt   @default(0)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model sc_vendor_invoices {
  id                 String             @id
  invoice_no         String             @unique
  store_slug         String
  order_line_id      String
  customer_name      String
  customer_phone     String
  store_name         String
  total              Decimal            @db.Decimal(12, 2)
  invoice_date       DateTime           @db.Date
  payload_json       String
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  sc_customer_orders sc_customer_orders @relation(fields: [order_line_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([store_slug])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sc_verification_requests {
  id             String    @id
  store_slug     String
  status         String
  payment_status String
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  resolved_at    DateTime? @db.Timestamptz(6)

  @@index([store_slug], map: "sc_verification_requests_slug_idx")
}

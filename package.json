{
  "name": "laas24",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "dev:pwa": "cross-env NEXT_PWA_DEV_MODE=1 next dev --webpack",
    "preview": "npm run build && next start",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true});console.log('Removed .next')}catch(e){if(e.code!=='ENOENT')throw e}\"",
    "dev:socket": "dotenv -e .env.local -e .env -- node socket-server.mjs",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "dotenv -e .env.local -e .env -- prisma generate",
    "db:pull": "dotenv -e .env.local -e .env -- prisma db pull",
    "db:push": "dotenv -e .env.local -e .env -- prisma db push",
    "db:studio": "dotenv -e .env.local -e .env -- prisma studio"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^8.0.4",
    "nprogress": "^0.2.0",
    "pdfkit": "^0.18.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "server-only": "^0.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/nprogress": "^0.2.3",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}

# PWA: default `npm run dev` has no service worker (Turbopack). Use `npm run dev:pwa` or `npm run preview` to test install / offline.
#
# Public site URL (no trailing slash). Used for SSR/WhatsApp links. Copy/share in the browser uses the current origin.
# NEXT_PUBLIC_BASE_URL=https://kulmiscart.com
# Legacy alias (still supported if NEXT_PUBLIC_BASE_URL is unset):
# NEXT_PUBLIC_APP_URL=https://kulmiscart.com

# Neon Postgres — copy to .env.local (never commit .env.local)
# https://neon.tech/docs/connect/connect-from-any-app
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
# If dev logs show Neon "fetch failed" / EACCES: allow Node in Windows Firewall, try another network/VPN, or use Neon's pooler host.
# Chat/vendor pages can spike to multi-second "application-code" time on cold Neon HTTP queries — prefer the pooler URL from the Neon dashboard (often `-pooler` in the host) for lower latency.

# Optional: real AI product drafts from `/api/ai/analyze-product-image` (vision). Without it, the API returns mock JSON.
# OPENAI_API_KEY=

# Prisma: the CLI only reads `.env` by default. This project uses npm scripts that load `.env.local` first:
#   npm run db:generate
#   npm run db:push
# Or copy DATABASE_URL into a root `.env` file.
#
# Windows EPERM on `prisma generate`: stop `npm run dev`, close apps locking node_modules, then:
#   Remove-Item -Recurse -Force node_modules\.prisma -ErrorAction SilentlyContinue; npm run db:generate
# Or add an exclusion for the project folder in antivirus.

# Optional: separate secret for admin session cookie (defaults to VENDOR_SESSION_SECRET or dev fallback)
# ADMIN_SESSION_SECRET=

# Admin entry URL (single path segment, no slashes). Public sign-in is `https://your-domain/{ADMIN_LOGIN_PATH}`.
# `/admin/login` returns 404. Set the same value in NEXT_PUBLIC_ADMIN_LOGIN_PATH so logout redirects correctly.
# ADMIN_LOGIN_PATH=secure-admin-portal-9x7a
# NEXT_PUBLIC_ADMIN_LOGIN_PATH=secure-admin-portal-9x7a

# Optional: require this value in the Admin access key field before email/password (generic error on failure).
# ADMIN_ACCESS_KEY=

# Ads / Vercel: `VERCEL=1` embeds uploaded ad images in the database (data URLs); disk uploads are not persistent on serverless.
# Set ADS_IMAGE_DATA_URL=1 locally to mimic production embedding when testing.
# ADS_IMAGE_DATA_URL=

# Vendor + customer session signing (set in production)
# VENDOR_SESSION_SECRET=

# Optional: HMAC for `GET /api/chat/socket-token` and `GET /api/notifications/socket-token` (Socket.IO room join). Defaults to VENDOR_SESSION_SECRET — set if the socket server and Next app should use a dedicated secret.
# SOCKET_TOKEN_SECRET=

# FCM (optional). Full service account JSON on one line — enables push when devices POST /api/notifications/fcm-token.
# Create a Web app in Firebase Console, add Web Push cert (VAPID) for the client, and host firebase-messaging-sw.js at site root per Firebase docs.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FCM_VAPID_KEY=

# Realtime chat: browser connects to Socket.IO (same host in prod or explicit URL). Required for instant delivery; otherwise chat falls back to polling.
# NEXT_PUBLIC_SOCKET_URL=http://localhost:4001
# SOCKET_PORT=4001
# SOCKET_CORS_ORIGIN=http://localhost:3000
#
# Next.js pushes persisted messages to the socket process (save-first, then broadcast — see POST /api/chat/messages).
# Same value in `.env.local` for `npm run dev` and `npm run dev:socket`. Socket listens on port 4002 by default for POST /internal/chat-broadcast.
# SOCKET_BROADCAST_SECRET=generate-a-long-random-string
# SOCKET_INTERNAL_BROADCAST_URL=http://127.0.0.1:4002
# SOCKET_INTERNAL_PORT=4002

# Session cookies: omit Secure on plain HTTP (auto-detected from the request URL).
# Force if needed: SESSION_COOKIE_SECURE=true | false
# SESSION_COOKIE_SECURE=

# Optional: customer session only (defaults to VENDOR_SESSION_SECRET)
# CUSTOMER_SESSION_SECRET=

# Password reset (Gmail: use an App Password, not your normal login — https://support.google.com/accounts/answer/185833)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-address@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM="KULMISCART <your-address@gmail.com>"
# Optional: extra entropy for OTP hashing (defaults to VENDOR_SESSION_SECRET)
# PASSWORD_RESET_OTP_PEPPER=
# Optional: sign the post-OTP reset step (defaults to VENDOR_SESSION_SECRET)
# PASSWORD_RESET_TOKEN_SECRET=
